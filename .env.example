# Copy to .env and fill in. Never commit .env.

# --- API keys (image + text generation) ---
FAL_KEY="YOUR_FAL_KEY"
FAL_MODEL="fal-ai/nano-banana-2/edit"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-5-mini"

# --- Deploy: domain + Basic Auth (used by Caddy) ---
# Point this domain's A record at the server IP first.
DOMAIN="mascot.example.com"
BASIC_AUTH_USER="team"
# Generate the hash on the server:
#   docker compose run --rm caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
BASIC_AUTH_HASH="REPLACE_WITH_CADDY_HASH"
